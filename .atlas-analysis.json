  "keyFeatures": [
    "Solicitud de créditos en línea con wizard multi-paso",
    "Firma digital electrónica con OTP mediante FirmaPlus",
    "Panel administrativo con estadísticas en tiempo real",
    "Gestión de convenios con empresas afiliadas a COMFACA",
    "Generación de documentos PDF contractuales vía FlaskPDF",
    "Validación de afiliados en tiempo real con API SISU",
    "Sistema de notificaciones in-app",
    "Almacenamiento de documentos en SFTP remoto",
    "Daemon de monitoreo de firmas pendientes (nohup)",
    "Autenticación JWT con sesiones de 8 horas y bcrypt"
  ],
